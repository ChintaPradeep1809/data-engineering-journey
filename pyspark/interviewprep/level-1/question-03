from pyspark.sql.functions import col

# Task 1
df.filter(col("salary") > 50000).select("name").show()

# Task 2
df.filter(col("department") == "IT").select("name").show()

# Task 3
df.filter(
    (col("salary") > 50000) &
    (col("department") == "IT")
).select("name").show()

# Task 4
df.filter(
    (col("department") == "HR") |
    (col("city") == "Chennai")
).select("name").show()













