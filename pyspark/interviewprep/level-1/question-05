from pyspark.sql.functions import col

# Task 1
df.orderBy(col("salary").desc()).show()

# Task 2
df.orderBy(col("salary").desc()).limit(3).show()

# Task 3
df.orderBy(
    col("department").asc(),
    col("salary").desc()
).show()
