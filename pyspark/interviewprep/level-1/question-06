from pyspark.sql.functions import col

# Task 1: Display employees whose salary is NULL
df.filter(col("salary").isNull()).show()
>from pyspark.sql.functions import col

# Task 1
df.filter(col("salary").isNull()).show()

# Task 2 & 3
df = df.na.fill({
    "salary": 0,
    "city": "Unknown"
})

# Task 4
df = df.na.drop(subset=["department"])

df.show()
# Task 2: Replace NULL salaries with 0
df = df.fillna({"salary": 0})

# Task 3: Replace NULL city values with "Unknown"
df = df.fillna({"city": "Unknown"})

# Task 4: Remove rows where department is NULL
df = df.filter(col("department").isNotNull())

# Display final DataFrame
df.show()

