LeetCode 3 — Happy Number

File — happy_number.py

class Solution:

    def isHappy(self, n):

        seen = set()

        while n != 1 and n not in seen:

            seen.add(n)

            total = 0

            while n > 0:

                digit = n % 10
                total += digit * digit
                n //= 10

            n = total

        return n == 1


obj = Solution()

print(obj.isHappy(19))

Output:

True


