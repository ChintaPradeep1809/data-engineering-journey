LeetCode 2 — Valid Anagram

File — valid_anagram.py

class Solution:

    def isAnagram(self, s, t):

        if len(s) != len(t):
            return False

        freq = {}

        for char in s:
            freq[char] = freq.get(char, 0) + 1

        for char in t:

            if char not in freq:
                return False

            freq[char] -= 1

            if freq[char] < 0:
                return False

        return True


obj = Solution()

print(obj.isAnagram("anagram", "nagaram"))

Output:

True


