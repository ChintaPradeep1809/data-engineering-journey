LeetCode 1 — Valid Parentheses

valid_parentheses.py

class Solution:

    def isValid(self, s):

        stack = []

        mapping = {
            ')': '(',
            '}': '{',
            ']': '['
        }

        for char in s:

            if char in mapping.values():

                stack.append(char)

            elif char in mapping.keys():

                if not stack or stack.pop() != mapping[char]:
                    return False

        return len(stack) == 0


obj = Solution()

print(obj.isValid("()[]{}"))

Output:

True


