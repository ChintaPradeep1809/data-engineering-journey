2. Two_sum
class Solution:
    def twoSum(self, nums, target):
        hashmap = {}
        for i, num in enumerate(nums):
            remaining = target - num
            if remaining in hashmap:
                return [hashmap[remaining], i]
            hashmap[num] = i
obj = Solution()
nums = [2, 7, 11, 15]
target = 9

print(obj.twoSum(nums, target))
