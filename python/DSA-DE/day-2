valid anagram
def isAnagram(s, t):
    if len(s) != len(t):
        return False
    freq = [0] * 26
    for ch in s:
        freq[ord(ch) - ord('a')] += 1
    for ch in t:
        freq[ord(ch) - ord('a')] -= 1
    for count in freq:
        if count != 0:
            return False
    return True
