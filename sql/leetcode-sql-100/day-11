## Answer 4 — Customers Ordering Back-to-Back Months
WITH months_cte AS (
SELECT DISTINCT customer_id,
       DATE_FORMAT(order_date, '%Y-%m') AS order_month
FROM Orders
),
x AS (
SELECT customer_id,
       order_month,
       LAG(order_month) OVER(
           PARTITION BY customer_id
           ORDER BY order_month
       ) prev_month
FROM months_cte
)
SELECT DISTINCT customer_id
FROM x
WHERE PERIOD_DIFF(
      REPLACE(order_month,'-',''),
      REPLACE(prev_month,'-','')
) = 1;
```

